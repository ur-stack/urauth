# Backend URL — the FastAPI task-manager example (packages/py/examples/fastapi-example)
# Overrides urAuth.baseURL set in nuxt.config.ts
NUXT_PUBLIC_UR_AUTH_BASE_URL=http://localhost:8000

# Session sealing password — REQUIRED in production (≥32 chars).
# In dev mode @urauth/nuxt auto-generates one and saves it here if this is blank.
NUXT_SESSION_PASSWORD=
